# Database (required for app and scripts)
# Local Postgres:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE
# Docker Compose (same host as app): use service name `postgres` and match POSTGRES_* below.
# Coolify / ozero.cloud: use the PostgreSQL resource "Internal URL" for the app container on the same server.
# For tools on your laptop against a public DB, use the external URL only if enabled; include ?sslmode=require when the host requires TLS.
DATABASE_URL=postgresql://user:password@localhost:5432/streamlivee

# Optional: pg pool tuning (lib/db.ts). Omit for defaults.
# PG_POOL_MAX=20
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=10000

# Docker Compose Postgres (optional overrides; defaults match streamlivee/streamlivee/streamlivee)
# POSTGRES_USER=streamlivee
# POSTGRES_PASSWORD=streamlivee
# POSTGRES_DB=streamlivee

# Cron (production). Vercel Cron sends Authorization: Bearer <CRON_SECRET> when this is set.
# Used by GET /api/cron/studio-subscription-reminders (daily Studio renewal emails).
# CRON_SECRET=

# App URL (links, uploads, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Customer-facing DNS instructions (Coolify / self-hosted). Set in deployment env — no vendor defaults.
# NEXT_PUBLIC_PLATFORM_A_RECORD_IP=203.0.113.10
# NEXT_PUBLIC_PLATFORM_CNAME_TARGET=live.your-domain.example.com
# Optional TXT prefix for verification records (default _verify)
# NEXT_PUBLIC_DOMAIN_VERIFICATION_TXT_PREFIX=_verify
# Optional: comma-separated hostname substrings that skip white-label branding (preview hosts)
# NEXT_PUBLIC_DEV_HOST_HINTS=preview.example.com

# Uploads (optional; default: ./uploads)
# UPLOAD_DIR=/var/app/uploads

# OAuth / integrations (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ENCRYPTION_KEY=

# Payment (optional)
# RAZORPAY_WEBHOOK_SECRET=

# Fal AI (optional, for image generation) — use @fal-ai/client (see app/api/generate-image)
# FAL_KEY=
# Optional: default is fal-ai/nano-banana-2; set FAL_IMAGE_MODEL=fal-ai/flux/schnell if your key has access (inputs differ; see lib/fal-image-input.ts)
# FAL_IMAGE_MODEL=fal-ai/nano-banana-2

# Cloudflare DNS (optional, for domain auto-config)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# Optional: Upstash Redis (HTTP cache; branding / db-queries — see lib/redis.ts). Omit to use DB only.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Legacy VPS (CloudJiffy / Jelastic): see docs/deploy-cloudjiffy.md if applicable.

# Production template (copy on server, never commit secrets):
# .env.production.example → .env.production
