# Database (required for app and scripts)
DATABASE_URL=postgresql://user:password@localhost:5432/streamlivee
# CloudJiffy / Jelastic production: use the Postgres node internal IP from the app VPS
# (see docs/deploy-cloudjiffy.md and scripts/jelastic-init-db.sql).

# Auth (required in production)
AUTH_SECRET=your-secret-at-least-32-chars
# Optional: JWT_SECRET (falls back to AUTH_SECRET)

# App URL (for auth callbacks and upload URLs)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Uploads (optional; default: ./uploads)
# UPLOAD_DIR=/var/app/uploads

# Domain/DNS (optional; for VPS/Docker custom host)
# NEXT_PUBLIC_PLATFORM_CNAME_TARGET=cname.yourhost.com
# NEXT_PUBLIC_PLATFORM_A_RECORD_IP=1.2.3.4

# OAuth / integrations (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ENCRYPTION_KEY=

# Payment (optional)
# RAZORPAY_WEBHOOK_SECRET=

# Fal AI (optional, for image generation)
# FAL_KEY=

# Cloudflare DNS (optional, for domain auto-config)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# Docker Compose (local): use postgres service hostname
# DATABASE_URL=postgresql://user:password@postgres:5432/streamlivee

# Production template (copy on VPS, never commit secrets):
# .env.production.example → .env.production
