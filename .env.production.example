# Copy to .env.production on the VPS (never commit .env.production).

NODE_ENV=production

# PostgreSQL — use internal LAN IP of the DB node from the app VPS (CloudJiffy / Jelastic).
DATABASE_URL=postgresql://streamlivee_app:CHANGE_ME@192.168.8.103:5432/streamlivee

AUTH_SECRET=generate-a-long-random-secret-at-least-32-characters

# Public URL (must match the browser origin, including https).
NEXTAUTH_URL=https://your-domain.example.com
NEXT_PUBLIC_APP_URL=https://your-domain.example.com

# Customer DNS instructions in admin UI (your platform host, not Vercel).
# NEXT_PUBLIC_PLATFORM_A_RECORD_IP=45.120.136.100
# NEXT_PUBLIC_PLATFORM_CNAME_TARGET=live.your-domain.example.com

# Optional: local file uploads directory is /app/uploads in Docker (volume recommended).

# Optional integrations — only if you use them
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# NEXT_PUBLIC_STACK_PROJECT_ID=
# STACK_SECRET_SERVER_KEY=
