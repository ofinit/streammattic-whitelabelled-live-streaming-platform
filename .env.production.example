# Copy to .env.production on the VPS (never commit .env.production).

NODE_ENV=production

# PostgreSQL
# Coolify / ozero.cloud: paste the database resource "Internal URL" into Coolify env (or this file on the server).
#   Use the internal hostname for the app container on the same server as Postgres — not localhost from the host OS.
#   "External URL" is only for tools on your laptop (e.g. migrations) if external access is enabled; do not commit secrets.
#   Add ?sslmode=require when connecting over the public internet. postgres:// and postgresql:// both work with node-pg.
# Legacy: CloudJiffy / Jelastic — internal LAN IP of the DB node from the app VPS (see docs/deploy-cloudjiffy.md).
DATABASE_URL=postgresql://streamlivee_app:CHANGE_ME@192.168.8.103:5432/streamlivee
# Example shape only (replace with your internal URL from Coolify):
# DATABASE_URL=postgresql://USER:PASSWORD@internal-service-hostname:5432/your_database_name

# Public URL (must match the browser origin, including https).
NEXT_PUBLIC_APP_URL=https://your-domain.example.com

# Required for correct customer-facing DNS instructions (apex A record and subdomain CNAME targets).
NEXT_PUBLIC_PLATFORM_A_RECORD_IP=203.0.113.10
NEXT_PUBLIC_PLATFORM_CNAME_TARGET=live.your-domain.example.com
# Optional: verification TXT host prefix (default _verify)
# NEXT_PUBLIC_DOMAIN_VERIFICATION_TXT_PREFIX=_verify

# Optional pg pool overrides (see .env.example)
# PG_POOL_MAX=20

# Uploads: WebP files under this directory (must match Docker volume). Default when unset is {cwd}/uploads.
UPLOAD_DIR=/app/uploads

# Optional integrations — only if you use them
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SMTP / Email (password reset, OTP, etc.)
# Ensure the host firewall allows OUTBOUND TCP 587 (STARTTLS) or 465 (SSL) to this host.
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# Note: SMTP_FROM is a fallback; the Display Name is typically set in the Admin Dashboard Settings.
SMTP_FROM="StreamLivee <noreply@your-verified-domain.com>"
# Optional: port 465 uses implicit TLS — set if your provider requires it
# SMTP_SECURE=true
# Optional: set to false only if you must use self-signed SMTP (not recommended)
# SMTP_TLS_REJECT_UNAUTHORIZED=false
# Optional: verbose nodemailer logging (logs secrets — use only when debugging)
# SMTP_DEBUG=1
